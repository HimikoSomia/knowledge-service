<% content_for :title, "Workspaces" %>

<div class="space-y-5">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm text-base-content/60">Organize documents into focused knowledge areas.</p>
    </div>

    <%= link_to "New workspace", new_workspace_path, class: "btn btn-primary btn-sm self-start sm:self-auto" %>
  </div>

  <div class="overflow-hidden rounded-lg border border-base-300 bg-base-100 shadow-sm">
    <div class="overflow-x-auto">
      <table class="table">
        <thead class="bg-base-200/70 text-xs uppercase text-base-content/60">
          <tr>
            <th class="w-12">#</th>
            <th>Workspace</th>
            <th>Description</th>
            <th class="text-right">Documents</th>
            <th>Updated</th>
            <th class="w-36 text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @workspaces.each_with_index do |workspace, index| %>
            <tr class="hover">
              <th class="text-base-content/50"><%= index + 1 %></th>
              <td>
                <%= link_to workspace.name, workspace, class: "font-semibold text-base-content hover:text-primary" %>
              </td>
              <td class="max-w-md text-base-content/70">
                <%= truncate(workspace.description.presence || "No description", length: 96) %>
              </td>
              <td class="text-right">
                <span class="badge badge-ghost"><%= workspace.documents.size %></span>
              </td>
              <td class="whitespace-nowrap text-base-content/60"><%= short_date_time(workspace.updated_at) %></td>
              <td>
                <div class="flex justify-end gap-2">
                  <%= link_to "View", workspace, class: "btn btn-ghost btn-xs" %>
                  <%= link_to "Edit", edit_workspace_path(workspace), class: "btn btn-ghost btn-xs" %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @workspaces.empty? %>
            <tr>
              <td colspan="6" class="py-12 text-center">
                <p class="font-medium text-base-content">No workspaces yet</p>
                <p class="mt-1 text-sm text-base-content/60">Create a workspace to group related documents.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

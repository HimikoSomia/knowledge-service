<header class="navbar min-h-16 border-b border-base-300 bg-base-100 px-4 sm:px-6">
  <div class="flex-1">
    <h1 class="text-base font-semibold text-base-content sm:text-lg"><%= content_for(:title) || "Dashboard" %></h1>
  </div>

  <nav class="flex items-center gap-2">
    <div class="dropdown dropdown-end">
      <button type="button" tabindex="0" class="btn btn-ghost btn-circle avatar avatar-placeholder">
        <div class="h-10 w-10 rounded-full bg-neutral text-neutral-content">
          <span><%= Current.user&.email_address.to_s.first&.upcase || "U" %></span>
        </div>
      </button>

      <ul tabindex="0" class="menu dropdown-content z-10 mt-3 w-48 rounded-box border border-base-300 bg-base-100 p-2 shadow">
        <li><a>Profile</a></li>
        <li><a>Account settings</a></li>
        <li><%= link_to "Sign out", session_path, data: { turbo_method: :delete } %></li>
      </ul>
    </div>
  </nav>
</header>

<% content_for :title, "Documents" %>

<div class="space-y-5">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <p class="text-sm text-base-content/60">Track ingestion status, document types, and workspace coverage.</p>
    </div>

    <%= link_to "New document", new_document_path, class: "btn btn-primary btn-sm self-start sm:self-auto" %>
  </div>

  <div class="overflow-hidden rounded-lg border border-base-300 bg-base-100 shadow-sm">
    <div class="overflow-x-auto">
      <table class="table">
        <thead class="bg-base-200/70 text-xs uppercase text-base-content/60">
          <tr>
            <th class="w-12">#</th>
            <th>Document</th>
            <th>Type</th>
            <th>Status</th>
            <th class="text-right">Chunks</th>
            <th class="text-right">Workspaces</th>
            <th>Updated</th>
            <th class="w-36 text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @documents.each_with_index do |document, index| %>
            <tr class="hover">
              <th class="text-base-content/50"><%= @pagy.offset + index + 1 %></th>
              <td>
                <%= link_to document.title, document, class: "font-semibold text-base-content hover:text-primary" %>
              </td>
              <td class="whitespace-nowrap text-base-content/70"><%= document.document_type.presence || "Unknown" %></td>
              <td>
                <span class="<%= status_badge_class(document.status) %>"><%= document.status %></span>
              </td>
              <td class="text-right text-base-content/70"><%= number_with_delimiter(document.chunk_count.to_i) %></td>
              <td class="text-right">
                <span class="badge badge-ghost"><%= document.workspaces.size %></span>
              </td>
              <td class="whitespace-nowrap text-base-content/60"><%= short_date_time(document.updated_at) %></td>
              <td>
                <div class="flex justify-end gap-2">
                  <%= link_to "View", document, class: "btn btn-ghost btn-xs" %>
                  <%= link_to "Edit", edit_document_path(document), class: "btn btn-ghost btn-xs" %>
                </div>
              </td>
            </tr>
          <% end %>

          <% if @documents.empty? %>
            <tr>
              <td colspan="8" class="py-12 text-center">
                <p class="font-medium text-base-content">No documents yet</p>
                <p class="mt-1 text-sm text-base-content/60">Add a document to start building searchable knowledge.</p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
